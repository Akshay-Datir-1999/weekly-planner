{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/weekly-planner-ui/browser",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.*\\.(js|css|ico|png|jpg|svg|woff|woff2|ttf|eot|json))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}